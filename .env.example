# ==============================================================================
# Project Ares — Environment Variables
# Copy this to .env and fill in your values.
# Only LANGCHAIN_API_KEY and BRAVE_SEARCH_API_KEY need real values to run.
# ==============================================================================

# ---------------------------------------------------------------------------
# Ollama
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
# How long Ollama keeps a model loaded after last use (1m = unload after 1 min)
OLLAMA_KEEP_ALIVE=1m
OLLAMA_ORCHESTRATOR_MODEL=qwen2.5:3b
OLLAMA_CRITIC_MODEL=phi4-mini
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---------------------------------------------------------------------------
# LangSmith (free tier — sign up at smith.langchain.com)
# ---------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ares

# ---------------------------------------------------------------------------
# Brave Search API (free tier — sign up at brave.com/search/api)
# ---------------------------------------------------------------------------
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# ---------------------------------------------------------------------------
# Database & Storage
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./ares.db
CHROMA_PERSIST_DIR=./chroma_db
OUTPUT_DIR=./output

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Frontend (used by Next.js)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
